# Copy to .env.local and fill in. Do not commit .env.local.

# ---- CLI / local usage (API key, no OAuth) ----
LINEAR_API_KEY=lin_api_...

# Optional: comma-separated team IDs to scope projects
# LINEAR_TEAM_IDS=team-id-1,team-id-2

# ---- Web app OAuth (required for hosted / multi-user usage) ----
# Create an OAuth app at: Linear → Settings → API → OAuth Applications
#
# LINEAR_CLIENT_ID=your_oauth_client_id
# LINEAR_CLIENT_SECRET=your_oauth_client_secret
# LINEAR_REDIRECT_URI=http://localhost:5173/auth/callback
#   For Vercel: use https://your-app.vercel.app/auth/callback (add in Linear OAuth app too)
#
# Generate a random secret (e.g.: openssl rand -base64 32)
# SESSION_SECRET=change-me-to-a-long-random-string
